# =====================================================
# LIBERIA - Environment Variables
# =====================================================
# Copy this file to .env.local and fill the values.
# Never commit .env.local to git.

# -----------------------------------------------------
# App
# -----------------------------------------------------
# Public URL of the deployed app. Used by metadata, robots, sitemap,
# and Stripe checkout success/cancel URLs (which intentionally never
# read the Origin header).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------
# Supabase
# -----------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (NEVER expose to client). Reserved for Phase 2 webhook
# persistence — not required for Phase 1 to build or run.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------
# Stripe (Phase 1: structure ready — optional for build)
# -----------------------------------------------------
# Server-only — drives /api/stripe/checkout and webhook signature verification.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Price IDs from your Stripe dashboard.
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_YEARLY=price_xxx
