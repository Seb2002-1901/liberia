# =====================================================
# LIBERIA - Environment Variables
# =====================================================
# Copy this file to .env.local and fill the values.
# Never commit .env.local to git.

# -----------------------------------------------------
# App
# -----------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LIBERIA

# -----------------------------------------------------
# Supabase
# -----------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------
# Stripe (Phase 1: structure ready, optional for build)
# -----------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_YEARLY=price_xxx
