# =====================================================
# LIBERIA - Environment Variables
# =====================================================
# Copy this file to .env.local and fill the values.
# Never commit .env.local to git.

# -----------------------------------------------------
# App
# -----------------------------------------------------
# Public URL of the deployed app. Used by metadata, robots, sitemap,
# and Stripe checkout success/cancel URLs (which intentionally never
# read the Origin header).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------
# Supabase
# -----------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (NEVER expose to client). Required in Phase 2 for the
# Stripe webhook to persist subscriptions and for the AI tables to be
# administered.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------
# Stripe
# -----------------------------------------------------
# Server-only — drives /api/stripe/checkout and webhook signature verification.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Price IDs from your Stripe dashboard.
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_YEARLY=price_xxx

# -----------------------------------------------------
# Anthropic (coach IA) — Phase 2
# -----------------------------------------------------
# Server-only. Required to activate /coach and /api/ai/chat.
# Default model: claude-sonnet-4-6 (configurable in lib/ai/client.ts).
ANTHROPIC_API_KEY=sk-ant-xxx

# -----------------------------------------------------
# Upstash Redis (rate-limit) — Phase 2 — optional in dev
# -----------------------------------------------------
# When absent the limiter no-ops (everything allowed). Required in
# production for /api/stripe/*, /api/ai/*, auth endpoints.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------
# Sentry — Phase 2 — optional in dev
# -----------------------------------------------------
# When absent the SDK no-ops. PII (emails, amounts, tokens) is stripped
# from every event in sentry.server.config.ts.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------
# Resend (emails hebdo) — Phase 3 — optional
# -----------------------------------------------------
# When absent, the weekly recap cron skips silently. Required for the
# /api/cron/weekly-recap endpoint to actually deliver mail.
RESEND_API_KEY=
RESEND_FROM_EMAIL=LIBERIA <coach@liberia.app>

# -----------------------------------------------------
# Cron (Vercel scheduled jobs) — Phase 3
# -----------------------------------------------------
# Shared secret that the cron endpoint requires via either:
#   - Authorization: Bearer <secret>
#   - x-cron-secret: <secret>
# (We deliberately do NOT accept the secret as a URL query parameter
#  to avoid leaks via access logs / browser history / referers.)
# Vercel Cron automatically signs requests with the project's CRON_SECRET
# in the Authorization header.
CRON_SECRET=

# -----------------------------------------------------
# Admin (operator-only) — optional
# -----------------------------------------------------
# Comma-separated list of Supabase user UUIDs allowed to view /admin.
# Unset → /admin returns 404 to everyone. Set to your own user.id
# (visible after first login in Supabase → Authentication → Users).
ADMIN_USER_IDS=
